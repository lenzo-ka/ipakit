    <feature name="syllabic" short="syl" type="binary" desc="Functions as syllable nucleus" href="Syllabic_consonant"/>

    <!-- Suprasegmental binary features -->
    <feature name="linking" short="lnk" type="binary" desc="Ties segments within a unit" href="Tie_(typography)"/>
    <feature name="liaison" short="lia" type="binary" desc="Links words across boundaries" href="Liaison_(French)"/>

    <!-- Diacritic multi-valued features -->
    <feature name="release" short="rel" desc="How stop closure is released" href="Consonant_release">
      <value name="aspirated" short="asp" href="Aspirated_consonant"/>
      <value name="breathy" short="brt" href="Breathy_voice"/>
      <value name="lateral" short="lrl" href="Lateral_release_(phonetics)"/>
      <value name="nasal" short="nrl" href="Nasal_release"/>
      <value name="no-audible" short="nau" href="No_audible_release"/>
    </feature>

    <feature name="rounding" short="rou" desc="Degree of lip rounding" href="Roundedness">
      <value name="less" short="les"/>
      <value name="more" short="mor"/>
    </feature>

    <feature name="phonation" short="phn" desc="Vocal fold vibration mode" href="Phonation">
      <value name="devoiced" short="dev" href="Voicelessness"/>
      <value name="breathy" short="brv" href="Breathy_voice"/>
      <value name="modal" short="mod" href="Modal_voice"/>
      <value name="creaky" short="crk" href="Creaky_voice"/>
    </feature>

    <!-- Suprasegmental multi-valued features -->
    <feature name="stress" short="str" desc="Prosodic prominence" href="Stress_(linguistics)">
      <value name="primary" short="1" href="Stress_(linguistics)"/>
      <value name="secondary" short="2" href="Secondary_stress"/>
    </feature>

    <feature name="tone" short="ton" desc="Pitch level" href="Tone_(linguistics)">
      <value name="bottom" short="t1"/>
      <value name="low" short="t2"/>
      <value name="mid" short="t3"/>
      <value name="high" short="t4"/>
      <value name="top" short="t5"/>
    </feature>

    <feature name="contour" short="ctr" desc="Pitch movement direction" href="Contour_tone">
      <value name="rising" short="R"/>
      <value name="falling" short="F"/>
    </feature>

    <feature name="break" short="brk" desc="Prosodic boundary strength" href="Prosodic_unit">
      <value name="minor" short="min"/>
      <value name="major" short="maj"/>
    </feature>

    <feature name="step" short="stp" desc="Register shift" href="Downstep">
      <value name="down" short="dn"/>
      <value name="up" short="up"/>
    </feature>

    <feature name="global" short="glb" desc="Utterance-level pitch change" href="Intonation_(linguistics)">
      <value name="rise" short="gR"/>
      <value name="fall" short="gF"/>
    </feature>

    <!-- Separator features -->
    <feature name="level" short="lvl" desc="Boundary level" href="Syllable">
      <value name="syllable" short="slb" href="Syllable"/>
      <value name="word" short="wrd" href="Word"/>
    </feature>
  </features>

