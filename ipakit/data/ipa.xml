    <feature name="centralized" short="ctz" type="binary" desc="Moved toward center" href="Relative_articulation#Centralization"/>
    <feature name="labialized" short="lbz" type="binary" desc="Secondary lip rounding" href="Labialization"/>
    <feature name="labio-palatized" short="lpz" type="binary" desc="Simultaneous labialization and palatalization"/>
    <feature name="mid-centralized" short="mcz" type="binary" desc="Moved toward schwa" href="Relative_articulation#Centralization"/>
    <feature name="palatalized" short="plz" type="binary" desc="Secondary palatal articulation" href="Palatalization_(phonetics)"/>
    <feature name="pharyngealized" short="phz" type="binary" desc="Secondary pharyngeal constriction" href="Pharyngealization"/>
    <feature name="height-mod" short="hmd" type="ternary" desc="Raised or lowered" href="Relative_articulation#Raising_and_lowering"/>
